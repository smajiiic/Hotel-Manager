# Where the dev server proxies /api/* in development. Override per-machine if backend
# runs on a different port. Leave unset in production — the SPA and API should be
# served same-origin so the session cookie is sent automatically.
VITE_API_PROXY=http://localhost:3000

# Optional: explicit API base URL used by the fetch wrapper. Only needed if the
# frontend is hosted on a different origin than the backend.
# VITE_API_BASE=https://api.example.com
