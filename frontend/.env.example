# Where the Vite dev server proxies /api/* in development. Override per-machine
# if the backend runs on a different port. Leave unset in production — the SPA
# and API should be served same-origin so the session cookie is sent
# automatically.
VITE_API_PROXY=http://localhost:5050

# Switch between the mock data layer (default) and the real backend for
# tasks + requests. The frontend ships with mock-backed `tasksApi.js` and
# `requestsApi.js` so dev / tests work without the backend running. Set this
# to `true` once `TaskService` and `RequestService` are live on the backend.
# (`/api/auth`, `/api/rooms`, `/api/bookings` always hit the real backend
# regardless of this flag — they don't have a mock layer in the frontend.)
VITE_USE_REAL_API=false

# Optional: explicit API base URL used by the fetch wrapper. Only needed if the
# frontend is hosted on a different origin than the backend.
# VITE_API_BASE=https://api.example.com
