    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Paste this in Scripts → Post-response for every request\r",
                  "\r",
                  "pm.test(\"Response is 200 OK\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response has success field\", function () {\r",
                  "    const json = pm.response.json();\r",
                  "    pm.expect(json).to.have.property(\"success\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Success is true\", function () {\r",
                  "    const json = pm.response.json();\r",
                  "    pm.expect(json.success).to.eql(true);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response time under 2000ms\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Login successful\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "    const json = pm.response.json();\r",
                  "    pm.expect(json.success).to.eql(true);\r",
                  "    pm.expect(json.data).to.have.property(\"role\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
